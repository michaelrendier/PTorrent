      "citation": "Zhang et al. 2006 A&A 457 45"
    },

    {
      "name": "erosita_dr1",
      "telescope": "eROSITA",
      "instrument": "eROSITA (TM1-7)",
      "waveband": "xray_soft",
      "role": "gas_tracer_allsky",
      "description": "eROSITA DR1 all-sky survey coverage of the Bullet Cluster field (0.2-2.3 keV). Lower depth than Chandra but uniform all-sky calibration. Cross-check for extended emission boundary. eROSITA-DE public DR1.",
      "mode": "fits",
      "url": "https://erosita.mpe.mpg.de/dr1/erodat/product_mosaics/",
      "value_col": "COUNTS",
      "j_expr": "COUNTS / BACKSCAL",
      "j_expr_cols": ["COUNTS", "BACKSCAL"],
      "auth": "none",
      "note": "Download region cutout: RA=104.6, Dec=-55.9, radius=0.5 deg. Product: eRASS:4 source catalog filtered by field.",
      "citation": "Merloni et al. 2024 A&A 682 A34"
    },

    {
      "name": "clowe2006_weak_lensing",
      "telescope": "HST ACS + Subaru SuprimeCam",
      "instrument": "ACS/WFC + SuprimeCam",
      "waveband": "optical_lensing",
      "role": "mass_map_primary",
      "description": "Weak gravitational lensing convergence κ map. THE foundational lensing paper for the Bullet Cluster. κ ≈ 0.05 outskirts, κ ≈ 0.25 gas centre, κ ≈ 0.35 at lensing wing peaks. The two κ peaks are OFFSET from the X-ray gas peak. In Lambda-CDM: dark matter halos. In SMMIP: constructive BEC interference peaks. The test: is there fringe substructure between the two κ peaks? BEC predicts alternating σ=1/σ=½ fringes. CDM predicts smooth σ=1 blobs.",
      "mode": "tap_adql",
      "endpoint": "https://tapvizier.cds.unistra.fr/TAPVizieR/tap",
      "query": "SELECT RAJ2000, DEJ2000, kappa, e_kappa FROM \"J/ApJL/648/L109/table1\" WHERE kappa IS NOT NULL ORDER BY kappa DESC",
      "j_expr": "kappa / 0.05",
      "j_expr_cols": ["kappa"],
      "auth": "none",
      "citation": "Clowe et al. 2006 ApJL 648 L109 (DOI: 10.1086/508162)",
      "key_prediction": "Lensing peaks at κ > 0.30 → J = κ/0.05 ≥ 6 → σ=2 (gravity). Gas centre at κ ≈ 0.15-0.25 → J = 3-5 → σ=1/2. Offset confirmed. BEC fringe test: extract σ-face profile along line connecting two κ peaks."
    },

    {
      "name": "bradac2006_strong_weak_lensing",
      "telescope": "HST ACS + VLT FORS2",
      "instrument": "ACS/WFC + FORS2",
      "waveband": "optical_lensing",
      "role": "mass_map_strong_lensing",
      "description": "Combined weak + strong lensing mass map. Strong lensing arcs pin the mass peaks to within arcseconds. The two mass concentration centres are at ~400 kpc separation (physical). In BEC model: two constructive interference maxima from the collision of two BEC cavities. The lensing arcs are the Einstein rings of the BEC interference peaks.",
      "mode": "tap_adql",
      "endpoint": "https://tapvizier.cds.unistra.fr/TAPVizieR/tap",
      "query": "SELECT RAJ2000, DEJ2000, zphot, Magr FROM \"J/ApJ/652/937/table1\" WHERE RAJ2000 IS NOT NULL",
      "j_expr": "1.0 / max(e_kappa, 0.001)",
      "j_expr_cols": ["e_kappa"],
      "auth": "none",
      "citation": "Bradač et al. 2006 ApJ 652 937 (DOI: 10.1086/507936)"
    },

