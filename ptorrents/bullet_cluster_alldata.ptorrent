    {
      "name": "harvey2015_stellar_gas_offset",
      "telescope": "HST (400-cluster sample)",
      "instrument": "ACS/WFC",
      "waveband": "optical_lensing",
      "role": "stellar_dark_matter_offset_400sample",
      "description": "Statistical measurement of the offset between stars and dark matter in 400 cluster collisions including the Bullet Cluster. Stellar mass found to track the dark matter — not the gas. CDM interpretation: stars and DM both collisionless. BEC interpretation: stars are leaves on the water (galaxy-scale resonant modes). The bowl (halo) naturally carries the leaves because the bowl IS the medium the leaves float in. Stars track the mode because they are IN the mode.",
      "mode": "tap_adql",
      "endpoint": "https://tapvizier.cds.unistra.fr/TAPVizieR/tap",
      "query": "SELECT Name, RAJ2000, DEJ2000, z, DM_offset, e_DM_offset, Star_offset, e_Star_offset FROM \"J/Sci/347/1462/table1\" WHERE Name IS NOT NULL",
      "j_expr": "DM_offset / max(Star_offset, 0.001)",
      "j_expr_cols": ["DM_offset", "Star_offset"],
      "auth": "none",
      "citation": "Harvey et al. 2015 Science 347 1462 (DOI: 10.1126/science.1261381)"
    },

