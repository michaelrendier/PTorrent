      "telescope": "H.E.S.S.",
      "instrument": "H.E.S.S. IACT array",
      "waveband": "tev_gamma_null",
      "role": "cdm_annihilation_null_highE",
      "description": "H.E.S.S. TeV gamma-ray search at the Bullet Cluster. NULL RESULT at 100 GeV - 10 TeV. Constrains heavy WIMP candidates (mass > 100 GeV). Combined with Fermi-LAT, the full WIMP mass range 1 GeV - 10 TeV is excluded or severely constrained. In BEC model: exactly as expected. The 'halo' is geometry. No particles. Nothing radiates at TeV energies.",
      "mode": "tap_adql",
      "endpoint": "https://tapvizier.cds.unistra.fr/TAPVizieR/tap",
      "query": "SELECT Name, RAJ2000, DEJ2000, TS, Flux, e_Flux FROM \"J/ApJ/750/123/table1\" WHERE RAJ2000 BETWEEN 103.8 AND 105.4 AND DEJ2000 BETWEEN -56.7 AND -55.2",
