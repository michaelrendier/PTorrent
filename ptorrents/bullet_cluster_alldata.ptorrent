    {
      "name": "fermi_lat_null_10yr",
      "telescope": "Fermi-LAT",
      "instrument": "LAT 100 MeV - 500 GeV",
      "waveband": "gamma_null",
      "role": "cdm_annihilation_null_PRIMARY",
      "description": "Fermi-LAT 10-year search for dark matter self-annihilation at the Bullet Cluster. NULL RESULT. This is THE most important data point for distinguishing BEC from CDM. CDM WIMPs should annihilate in the dense halo cores: χχ → γγ, bb̄, W+W−. The resulting gamma-ray flux is proportional to the DM density squared. In the BEC model: the 'halo' is a resonant wave mode — there are NO particles in it. Nothing to annihilate. The null result IS the BEC prediction. This null is not a failure — it is a confirmation.",
      "mode": "tap_adql",
      "endpoint": "https://heasarc.gsfc.nasa.gov/xamin/vo/tap",
      "query": "SELECT name, ra, dec, flux_100_300000, pivot_energy, flux_unc, assoc_prob FROM fermilpsc WHERE ra BETWEEN 103.8 AND 105.4 AND dec BETWEEN -56.7 AND -55.2",
      "j_expr": "flux_100_300000 / 1e-11",
      "j_expr_cols": ["flux_100_300000"],
      "note": "Expected: NO source detected at Bullet Cluster position. If this query returns rows: those are background AGN/pulsars, not DM annihilation. Evaluate upper limit vs CDM prediction separately using Ackermann 2015 Table 3.",
      "auth": "none",
      "citation": "Ackermann et al. 2015 JCAP 09 008 (DOI: 10.1088/1475-7516/2015/09/008)",
      "key_result": "Upper limit on <σv> is 10-100× below CDM thermal relic cross-section. The WIMP is not there. The BEC has no particle content. The null IS the prediction."
    },

