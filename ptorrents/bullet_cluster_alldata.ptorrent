      "instrument": "ACS/WFC F606W + F814W",
      "waveband": "optical",
      "role": "galaxy_catalog",
      "description": "HST ACS photometric catalog of galaxies in the Bullet Cluster field. Morphologies, photometric redshifts, magnitude distribution. Cluster membership selection. Source catalog for weak lensing shape measurement. Member galaxies = leaves on the water.",
      "mode": "tap_adql",
      "endpoint": "https://mast.stsci.edu/tap/sync",
      "query": "SELECT s_ra, s_dec, t_exptime, obs_collection, filters, calib_level FROM ivoa.obscore WHERE s_ra BETWEEN 103.8 AND 105.4 AND s_dec BETWEEN -56.7 AND -55.2 AND obs_collection='HST' AND calib_level=2",
      "j_expr": "t_exptime / 1000.0",
