{
  "ptorrent_version": "2.0",
  "type": "dataset",
  "name": "Bullet Cluster — All-Telescope Dataset + σ-Face Evaluation",
  "requires_bin": "monad_physics.bin",
  "output": "bullet_cluster_alldata.peval",
  "primary_tags": [
    "BULLET_CLUSTER", "1E0657-558", "DARK_MATTER", "BEC", "LAMBDA_CDM",
    "XRAY", "LENSING", "RADIO", "SZ", "GAMMA_NULL", "OPTICAL", "MULTIWAVELENGTH"
  ],
  "color": "cyan",
  "description": "All-telescope dataset traversal of the Bullet Cluster (1E 0657-558). Every instrument that resolved this cluster. Per-instrument σ-face evaluation. J = signal / ambient per waveband. BEC prediction: lensing peaks → σ=1 (Yang-Mills), gas peaks → σ=½ (causality), gamma nulls confirm no CDM annihilation. Gravity is not a stuff — it is a shape with inside and outside. The halo IS the shape. Nothing to detect.",

  "field_centre": {
    "ra_deg": 104.6098,
    "dec_deg": -55.9446,
    "radius_arcmin": 20.0,
    "note": "1E 0657-558 / Bullet Cluster. RA 6h 58m 27.8s, Dec -55° 56' 41\" (J2000). Radius covers both lensing peaks + radio relic + bow shock."
  },

  "sources": [

    {
      "name": "chandra_acis_main",
      "telescope": "Chandra",
      "instrument": "ACIS-I",
      "waveband": "xray_soft",
      "role": "gas_tracer_primary",
      "description": "Chandra ACIS-I ObsIDs 3184 + 5356 combined, 0.5-2 keV, ~500 ks. The definitive X-ray gas map of the collision. The 'Bullet' subcluster bow shock is visible at ~0.7 Mpc east of centre. Gas stopped here. Mass (lensing) passed through. This is the dataset that defines the Bullet Cluster observation.",
      "mode": "tap_adql",
      "endpoint": "https://heasarc.gsfc.nasa.gov/xamin/vo/tap",
      "query": "SELECT name, ra, dec, exposure, obsid, instrument, grating, target_name FROM chanmaster WHERE ra BETWEEN 103.8 AND 105.4 AND dec BETWEEN -56.7 AND -55.2 AND instrument LIKE 'ACIS%'",
      "j_expr": "exposure / 100000.0",
      "j_expr_cols": ["exposure"],
      "auth": "none",
      "citation": "Markevitch et al. 2004 ApJL 606 L819; Clowe et al. 2006 ApJL 648 L109"
    },

    {
      "name": "chandra_acis_deep",
      "telescope": "Chandra",
      "instrument": "ACIS-I",
      "waveband": "xray_soft",
      "role": "gas_tracer_deep",
      "description": "Additional Chandra ObsIDs 4970, 5361 — deeper follow-up observations. Temperature map, hardness ratio, bow shock velocity measurement. Mach number M~3 from bow shock geometry.",
      "mode": "tap_adql",
      "endpoint": "https://heasarc.gsfc.nasa.gov/xamin/vo/tap",
      "query": "SELECT name, ra, dec, exposure, obsid, instrument FROM chanmaster WHERE ra BETWEEN 103.8 AND 105.4 AND dec BETWEEN -56.7 AND -55.2 AND obsid IN (4970, 5361)",
      "j_expr": "exposure / 100000.0",
      "j_expr_cols": ["exposure"],
      "auth": "none",
      "citation": "Markevitch 2006 ESA SP-604 723"
    },

    {
      "name": "xmm_newton_epic",
      "telescope": "XMM-Newton",
      "instrument": "EPIC-MOS + PN",
      "waveband": "xray_soft",
      "role": "gas_tracer_independent",
      "description": "XMM-Newton ObsID 0112980201. Independent temperature and abundance map. Cross-validates Chandra bow shock geometry. Lower resolution but higher collecting area — better entropy map at large radii.",
      "mode": "tap_adql",
      "endpoint": "https://nxsa.esac.esa.int/nxsa-sl/tap",
      "query": "SELECT target_name, ra, dec, duration, obs_id, instrument FROM v_public_observations WHERE ra BETWEEN 103.8 AND 105.4 AND dec BETWEEN -56.7 AND -55.2",
      "j_expr": "duration / 50000.0",
      "j_expr_cols": ["duration"],
