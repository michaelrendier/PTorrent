      "instrument": "ACS + WFC3",
      "waveband": "optical_lensing",
      "role": "mass_map_hff",
      "description": "Hubble Frontier Fields strong lensing model of the Bullet Cluster. Full HFF depth (HST program 13386). Highest resolution mass map of the two peaks. Lensing model includes 30+ multiple image systems. Peak mass positions confirmed to sub-arcsecond precision.",
      "mode": "tap_adql",
      "endpoint": "https://tapvizier.cds.unistra.fr/TAPVizieR/tap",
      "query": "SELECT RAJ2000, DEJ2000, Mag, e_Mag, zphot FROM \"J/A+A/594/A121/table1\" WHERE RAJ2000 IS NOT NULL",
